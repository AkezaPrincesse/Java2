Statement  : -- =====================================================
-- V8: Stored Procedures and Functions
-- =====================================================

-- Procedure: Generate monthly bills for all active meters
CREATE OR REPLACE PROCEDURE sp_generate_monthly_bills(p_year INT, p_month INT)
LANGUAGE plpgsql AS $$
DECLARE
    v_cycle_id      BIGINT;
    v_due_date      DATE;
    v_bill_number   VARCHAR(30);
    v_meter         RECORD;
    v_reading       RECORD;
    v_tariff        RECORD;
    v_consumption   NUMERIC := 0;
    v_total         NUMERIC := 0;
    v_bills_created INT := 0;
BEGIN
    v_due_date := (DATE (p_year || '-' || LPAD(p_month::TEXT, 2, '0') || '-01') + INTERVAL '1 month' + INTERVAL '15 days')::DATE;

    INSERT INTO billing_cycles (billing_year, billing_month, start_date, end_date, due_date, created_by)
    VALUES (p_year, p_month,
            DATE(p_year || '-' || LPAD(p_month::TEXT, 2,'0') || '-01'),
            (DATE(p_year || '-' || LPAD(p_month::TEXT, 2,'0') || '-01') + INTERVAL '1 month - 1 day')::DATE,
            v_due_date, 'SYSTEM')
    ON CONFLICT (billing_year, billing_month) DO UPDATE SET updated_at = CURRENT_TIMESTAMP
    RETURNING id INTO v_cycle_id;

    FOR v_meter IN
        SELECT m.id, m.meter_type, m.customer_id, m.tariff_id
        FROM meters m
        JOIN customers c ON c.id = m.customer_id
        WHERE m.status = 'ACTIVE' AND c.status = 'ACTIVE'
    LOOP
        IF EXISTS (SELECT 1 FROM bills WHERE meter_id = v_meter.id AND billing_cycle_id = v_cycle_id) THEN
            CONTINUE;
        END IF;

        SELECT COALESCE(consumption, 0) INTO v_consumption
        FROM meter_readings
        WHERE meter_id = v_meter.id AND reading_year = p_year AND reading_month = p_month
        LIMIT 1;

        v_total := v_consumption * COALESCE(
            (SELECT flat_rate FROM tariffs WHERE id = v_meter.tariff_id AND active = TRUE), 200
        );

        v_bill_number := CASE WHEN v_meter.meter_type = 'WATER' THEN 'WB' ELSE 'EB' END
            || '-' || p_year || LPAD(p_month::TEXT, 2, '0')
            || '-' || LPAD((EXTRACT(EPOCH FROM NOW())::BIGINT % 999999)::TEXT, 6, '0');

        INSERT INTO bills (
            bill_number, customer_id, meter_id, billing_cycle_id,
            utility_type, consumption_amount, service_charge_amount, tax_amount,
            penalty_amount, total_amount, paid_amount, balance_amount,
            status, bill_date, due_date, created_by
        ) VALUES (
